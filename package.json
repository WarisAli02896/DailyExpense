    "@react-navigation/native-stack": "^7.13.0",
    "expo": "~54.0.33",
    "expo-auth-session": "~7.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-print": "~15.0.8",
    "expo-sharing": "~14.0.8",
